  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "plist": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/plist": "^3.0.5",
    "typescript": "^5.7.0"
  }
